# SaveSlate — Production environment variables
# Copy to .env and fill in real values before deploying.

# ---------- PostgreSQL ----------
POSTGRES_USER=saveslate
POSTGRES_PASSWORD=          # REQUIRED — generate a strong password
POSTGRES_DB=saveslate

# ---------- API ----------
# JWT signing key — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=                 # REQUIRED
# CSRF double-submit cookie secret
CSRF_SECRET_KEY=            # REQUIRED

# Comma-separated CORS origins (set to your domain in production)
CORS_ORIGINS=http://localhost

# ---------- Docker ----------
# Host port for the web service (default 80)
PORT=80
