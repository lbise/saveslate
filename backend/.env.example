# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://saveslate:saveslate@localhost:5432/saveslate

# JWT secret – generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret

# CSRF double-submit cookie secret
CSRF_SECRET_KEY=change-me-to-another-random-secret

# JWT token lifetime in minutes (default 1440 = 24h)
JWT_EXPIRE_MINUTES=1440

# Comma-separated CORS origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
